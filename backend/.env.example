# OPC Backend Environment

# App
APP_NAME="OPC - One Prompt Creates"
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# Database (Postgres + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/opc

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM Provider: anthropic | openai | minimax
LLM_PROVIDER=minimax

# Agnes API (OpenAI-compatible) - 保留以备切换
OPENAI_API_KEY=your_agnes_api_key_here
OPENAI_BASE_URL=https://apihub.agnes-ai.com/v1
OPENAI_MODEL=agnes-2.0-flash
OPENAI_ENABLE_THINKING=false
OPENAI_THINKING_BUDGET_TOKENS=2048

# MiniMax M3 (Anthropic-compatible API)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M3

# JWT
JWT_SECRET=dev-only-change-me-in-production-32chars-min
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage
GENERATED_PROJECTS_DIR=generated-projects

# Stripe (subscriptions + customer portal)
# 留空则订阅功能不可用, 但 OPC 仍可用 dev credits 工作
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# 在 Stripe Dashboard 创建 6 个 price (lite/pro/max × monthly/yearly) 后填入 price_id
STRIPE_PRICE_LITE_MONTHLY=
STRIPE_PRICE_LITE_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_MAX_MONTHLY=
STRIPE_PRICE_MAX_YEARLY=
APP_BASE_URL=http://localhost:3000

# Sentry (error monitoring, optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
