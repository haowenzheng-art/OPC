# 运行模式
# - cli: 命令行模式（默认）
# - feishu: 飞书机器人模式
OPC_MODE=cli

# LLM配置（火山引擎）
USE_LLM=true
OPENAI_API_KEY=your_api_key_here
API_BASE_URL=https://apihub.agnes-ai.com/v1
MODEL_NAME=agnes-2.0-flash

# 飞书6个Bot配置（仅OPC_MODE=feishu时需要）
USE_FEISHU=false
FEISHU_GROUP_CHAT_ID=oc_xxxxxx
FEISHU_BOT_PORT=3000

# CEO Bot（接收用户私聊，负责协调）
FEISHU_CEO_APP_ID=cli_xxxxxx
FEISHU_CEO_APP_SECRET=xxxxxx
FEISHU_CEO_VERIFICATION_TOKEN=xxxxxx
FEISHU_CEO_ENCRYPT_KEY=xxxxxx

# PM Bot
FEISHU_PM_APP_ID=cli_xxxxxx
FEISHU_PM_APP_SECRET=xxxxxx

# Frontend Bot
FEISHU_FRONTEND_APP_ID=cli_xxxxxx
FEISHU_FRONTEND_APP_SECRET=xxxxxx

# Backend Bot
FEISHU_BACKEND_APP_ID=cli_xxxxxx
FEISHU_BACKEND_APP_SECRET=xxxxxx

# Test Bot
FEISHU_TEST_APP_ID=cli_xxxxxx
FEISHU_TEST_APP_SECRET=xxxxxx

# Ops Bot
FEISHU_OPS_APP_ID=cli_xxxxxx
FEISHU_OPS_APP_SECRET=xxxxxx

# 数据库配置
DATABASE_URL="file:./data/db.sqlite"
