{
  "name": "opc",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:feishu": "node -r dotenv/config --import tsx/esm src/index.ts dotenv_config_path=.env.feishu",
    "start": "node dist/index.js",
    "start:feishu": "node -r dotenv/config dist/index.js dotenv_config_path=.env.feishu",
    "test": "vitest",
    "test:unit": "vitest tests/unit/",
    "test:integration": "vitest tests/integration/",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.66.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@prisma/client": "^5.20.0",
    "body-parser": "^2.2.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "xstate": "^5.31.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.7",
    "prisma": "^5.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
